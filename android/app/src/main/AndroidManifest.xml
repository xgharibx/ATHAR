<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>

        <!-- Prayer Times Widget (4×3) -->
        <receiver
            android:name=".NoorPrayerFullWidgetProvider"
            android:exported="true"
            android:label="@string/widget_prayer_full_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_prayer_full_info" />
        </receiver>
        <!-- Daily Adhkar Progress Widget (4×2) -->
        <receiver
            android:name=".NoorAdhkarWidgetProvider"
            android:exported="true"
            android:label="@string/widget_adhkar_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_adhkar_info" />
        </receiver>
        <!-- Quran Wird Progress Widget (4×2) -->
        <receiver
            android:name=".NoorWirdWidgetProvider"
            android:exported="true"
            android:label="@string/widget_wird_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_wird_info" />
        </receiver>
        <!-- Daily Dashboard Widget (4×4) -->
        <receiver
            android:name=".NoorDashboardWidgetProvider"
            android:exported="true"
            android:label="@string/widget_dashboard_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_dashboard_info" />
        </receiver>

        <!-- General Daily Widget (3×2) -->
        <receiver
            android:name=".NoorWidgetProvider"
            android:exported="true"
            android:label="@string/widget_daily_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/noor_widget_info" />
        </receiver>

        <!-- Compact Daily Widget (2×1) -->
        <receiver
            android:name=".NoorCompactWidgetProvider"
            android:exported="true"
            android:label="@string/widget_compact_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/noor_widget_compact_info" />
        </receiver>

        <!-- Prayer Countdown Widget (4×2) -->
        <receiver
            android:name=".NoorPrayerWidgetProvider"
            android:exported="true"
            android:label="@string/widget_prayer_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/noor_widget_prayer_info" />
        </receiver>

        <!-- Sunnah Widget (4×2) -->
        <receiver
            android:name=".NoorSunnahWidgetProvider"
            android:exported="true"
            android:label="@string/widget_sunnah_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/noor_widget_sunnah_info" />
        </receiver>

        <!-- Interactive Tasbeeh Widget (2×2) -->
        <receiver
            android:name=".NoorTasbeehWidgetProvider"
            android:exported="true"
            android:label="@string/widget_tasbeeh_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.athar.adhkar.TASBEEH_INCREMENT" />
                <action android:name="com.athar.adhkar.TASBEEH_RESET" />
                <action android:name="com.athar.adhkar.TASBEEH_NEXT" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/noor_widget_tasbeeh_info" />
        </receiver>

        <!-- Asma al-Husna Daily Widget (4×2) -->
        <receiver
            android:name=".NoorAsmaWidgetProvider"
            android:exported="true"
            android:label="@string/widget_asma_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_asma_info" />
        </receiver>

        <!-- Qibla Direction Widget (2×2) -->
        <receiver
            android:name=".NoorQiblaWidgetProvider"
            android:exported="true"
            android:label="@string/widget_qibla_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_qibla_info" />
        </receiver>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Prayer times, Qibla, and nearby mosques -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <!-- Local Notifications -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <!-- Sebha voice counting -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-feature android:name="android.hardware.location.gps" android:required="false" />
    <uses-feature android:name="android.hardware.microphone" android:required="false" />
</manifest>
