<?xml version="1.0" encoding="utf-8"?>
<!-- Quran wird progress widget — 4×2 default, resizable -->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:initialLayout="@layout/widget_wird"
    android:minWidth="250dp"
    android:minHeight="150dp"
    android:minResizeWidth="210dp"
    android:minResizeHeight="140dp"
    android:previewLayout="@layout/widget_wird"
    android:resizeMode="horizontal|vertical"
    android:targetCellWidth="4"
    android:targetCellHeight="2"
    android:updatePeriodMillis="1800000"
    android:widgetCategory="home_screen"
    android:configure="com.athar.adhkar.WidgetConfigActivity"
    android:description="@string/widget_wird_description" />
