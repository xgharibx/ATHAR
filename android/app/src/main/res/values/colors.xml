<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="colorPrimary">#2F4F37</color>
    <color name="colorPrimaryDark">#1a2e1e</color>
    <color name="colorAccent">#7EC8A4</color>
    <!-- App dark background — prevents white/black flash while WebView loads -->
    <color name="colorBackground">#0a0c12</color>
    <!-- Splash screen background — matches the real brand logo background -->
    <color name="colorSplashBg">#2F4F37</color>

    <!--
      Widget text-color tokens — light-on-dark, the default for BOTH system
      modes.

      The widget's look is now driven by the user's per-widget THEME choice
      (COSMIC / EMERALD / LIGHT — see WidgetCanvas), NOT the system's
      light/dark setting: a user who picks COSMIC gets the deep-space widget
      whether their phone is in light or dark mode. Since COSMIC and EMERALD
      are both dark backgrounds and are the default, these text tokens are
      light-on-dark and identical in values/ and (implicitly) night mode, so
      those two themes stay readable in either system mode with no Java. The
      opt-in LIGHT theme needs dark ink instead, which its provider path sets
      programmatically (it can't be a system-mode resource qualifier, because
      the theme is independent of system mode). Tones mirror the in-app dark
      theme so widgets read as the same product.
    -->
    <color name="widget_text_primary">#FFFFFF</color>
    <color name="widget_text_secondary">#C9DCC9</color>
    <color name="widget_text_accent">#FFE8B0</color>

    <!--
      Row-state tokens — the "next / passed / future" language used by the
      prayer-list and dashboard-dot rows.
    -->
    <color name="widget_row_active">#FFE8B0</color>
    <color name="widget_row_active_time">#FFFFFF</color>
    <color name="widget_row_passed">#7AAB80</color>
    <color name="widget_row_passed_time">#4A6B50</color>
    <color name="widget_row_future">#C8DBC0</color>
    <color name="widget_row_future_time">#A8C4A8</color>
    <color name="widget_accent_blue">#88BBEE</color>
    <color name="widget_accent_dusk">#C8CCFF</color>
    <color name="widget_hairline">#22FFFFFF</color>

    <!--
      LIGHT-theme ink — used programmatically (not a resource qualifier) when
      a widget's chosen theme is THEME_LIGHT, since that choice is independent
      of the system's light/dark mode. Mirrors the in-app light theme's ink
      (globals.css fg / fg-dim custom properties) and the old row-state tones.
    -->
    <color name="widget_l_text_primary">#1A1D29</color>
    <color name="widget_l_text_secondary">#5B5F70</color>
    <color name="widget_l_text_accent">#9A7326</color>
    <color name="widget_l_row_active">#9A7326</color>
    <color name="widget_l_row_active_time">#1A1D29</color>
    <color name="widget_l_row_passed">#7C9A82</color>
    <color name="widget_l_row_passed_time">#9BAE9E</color>
    <color name="widget_l_row_future">#8A8F80</color>
    <color name="widget_l_row_future_time">#A8AC9E</color>
    <color name="widget_l_accent_blue">#3E6FB0</color>
    <color name="widget_l_accent_dusk">#5D6BC0</color>
    <color name="widget_l_hairline">#22000000</color>
</resources>
