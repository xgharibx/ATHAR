<?xml version="1.0" encoding="utf-8"?>
<!--
  Widget text-color tokens — DARK theme override.

  These match the colors that were previously hardcoded directly in each
  widget layout XML, so dark-mode devices (the majority of existing users,
  given the app's own default theme is dark) see no visual change from this
  refactor — only light-mode devices newly get a readable, theme-correct
  widget instead of dark cream-on-navy text surviving unchanged onto a
  bright sky background.
-->
<resources>
    <color name="widget_text_primary">#FFFFFF</color>
    <color name="widget_text_secondary">#C9DCC9</color>
    <color name="widget_text_accent">#FFE8B0</color>

    <color name="widget_row_active">#FFE8B0</color>
    <color name="widget_row_active_time">#FFFFFF</color>
    <color name="widget_row_passed">#7AAB80</color>
    <color name="widget_row_passed_time">#4A6B50</color>
    <color name="widget_row_future">#C8DBC0</color>
    <color name="widget_row_future_time">#A8C4A8</color>
    <color name="widget_accent_blue">#88BBEE</color>
    <color name="widget_hairline">#22FFFFFF</color>
</resources>
