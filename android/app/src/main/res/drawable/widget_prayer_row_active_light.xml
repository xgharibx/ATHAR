<?xml version="1.0" encoding="utf-8"?>
<!-- Active-row highlight for the LIGHT theme — warm cream so the gold
     text/stroke reads as "highlighted" rather than muddy against a bright
     sky. Selected programmatically when the widget's theme is THEME_LIGHT. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <corners android:radius="16dp" />
    <gradient
        android:angle="135"
        android:startColor="#FFF3D6"
        android:endColor="#FFE7B8" />
    <stroke
        android:width="1dp"
        android:color="#669A7326" />
</shape>
