<?xml version="1.0" encoding="utf-8"?>
<!-- Dashboard widget — royal emerald depth -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="26dp" />
            <gradient
                android:angle="270"
                android:startColor="#14402C"
                android:centerColor="#0C2819"
                android:endColor="#05110B" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="26dp" />
            <gradient
                android:angle="270"
                android:startColor="#16F6DFA4"
                android:endColor="#00000000"
                android:centerY="0.2" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="26dp" />
            <stroke android:width="1dp" android:color="#42EAC98A" />
        </shape>
    </item>
</layer-list>
