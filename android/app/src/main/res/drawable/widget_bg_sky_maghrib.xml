<?xml version="1.0" encoding="utf-8"?>
<!-- Maghrib — sunset embers fading into night -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="26dp" />
            <gradient
                android:angle="270"
                android:startColor="#5C2A1A"
                android:centerColor="#33201E"
                android:endColor="#0B1014" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="26dp" />
            <gradient
                android:angle="270"
                android:startColor="#33FFB27A"
                android:endColor="#00000000"
                android:centerY="0.22" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="26dp" />
            <stroke android:width="1dp" android:color="#47FFB27A" />
        </shape>
    </item>
</layer-list>
