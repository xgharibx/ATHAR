<?xml version="1.0" encoding="utf-8"?>
<!-- Active (next-prayer) row highlight — dark-green, the default used by the
     COSMIC and EMERALD themes (both dark). The LIGHT theme swaps in
     widget_prayer_row_active_light programmatically. Theme is independent of
     system light/dark mode, so this can't be a -night resource qualifier. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <corners android:radius="16dp" />
    <gradient
        android:angle="135"
        android:startColor="#3D5E40"
        android:endColor="#2A4530" />
    <stroke
        android:width="1dp"
        android:color="#66EAD58D" />
</shape>
