<?xml version="1.0" encoding="utf-8"?>
<!-- Light theme (dark override in drawable-night/) — warm cream highlight
     instead of the dark set's olive-green, so the gold text/stroke still
     reads as "highlighted" rather than muddy against a bright sky. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <corners android:radius="16dp" />
    <gradient
        android:angle="135"
        android:startColor="#FFF3D6"
        android:endColor="#FFE7B8" />
    <stroke
        android:width="1dp"
        android:color="#669A7326" />
</shape>
