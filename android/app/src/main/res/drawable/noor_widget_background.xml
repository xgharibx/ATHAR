<?xml version="1.0" encoding="utf-8"?>
<!-- Athar widget base — deep emerald night with a gold hairline + top sheen -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="26dp" />
            <gradient
                android:angle="270"
                android:startColor="#123A28"
                android:centerColor="#0B241A"
                android:endColor="#06130D" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="26dp" />
            <gradient
                android:angle="270"
                android:startColor="#14FFFFFF"
                android:centerColor="#00FFFFFF"
                android:endColor="#00000000"
                android:centerY="0.28" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="26dp" />
            <stroke android:width="1dp" android:color="#3DEAC98A" />
        </shape>
    </item>
</layer-list>
