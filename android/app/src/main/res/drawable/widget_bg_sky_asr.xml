<?xml version="1.0" encoding="utf-8"?>
<!-- Asr — golden afternoon: olive-gold light over green -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="26dp" />
            <gradient
                android:angle="270"
                android:startColor="#4A3D1E"
                android:centerColor="#2A2E18"
                android:endColor="#0B160E" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="26dp" />
            <gradient
                android:angle="270"
                android:startColor="#2EF6DFA4"
                android:endColor="#00000000"
                android:centerY="0.24" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="26dp" />
            <stroke android:width="1dp" android:color="#47EAC98A" />
        </shape>
    </item>
</layer-list>
