<?xml version="1.0" encoding="utf-8"?>
<!-- Adhkar widget — dawn-to-dusk teal with gold hairline -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/widget_corner_radius" />
            <gradient
                android:angle="270"
                android:startColor="#153A44"
                android:centerColor="#0D2630"
                android:endColor="#071318" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/widget_corner_radius" />
            <gradient
                android:angle="270"
                android:startColor="#16FFE8B0"
                android:endColor="#00000000"
                android:centerY="0.25" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/widget_corner_radius" />
            <stroke android:width="1dp" android:color="#3D8FD4E8" />
        </shape>
    </item>
</layer-list>
