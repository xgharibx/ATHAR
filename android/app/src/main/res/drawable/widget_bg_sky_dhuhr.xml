<?xml version="1.0" encoding="utf-8"?>
<!-- Dhuhr — high sun: bright emerald noon -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="26dp" />
            <gradient
                android:angle="270"
                android:startColor="#1B5A3C"
                android:centerColor="#0F3A26"
                android:endColor="#081B12" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="26dp" />
            <gradient
                android:angle="270"
                android:startColor="#26FFF2C0"
                android:endColor="#00000000"
                android:centerY="0.22" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="26dp" />
            <stroke android:width="1dp" android:color="#42F0D68A" />
        </shape>
    </item>
</layer-list>
