<?xml version="1.0" encoding="utf-8"?>
<!--
  Ultimate Interactive Tasbeeh Widget (2×2)
  - Central tap zone increments the counter without opening the app
  - Shows dhikr name in Arabic, big count, progress "X / Y"
  - Reset (bottom-left) and Next Dhikr (bottom-right) buttons
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/tasbeeh_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/noor_widget_background"
    android:padding="12dp">

    <!-- Central tap zone — occupies full widget, increments count -->
    <LinearLayout
        android:id="@+id/tasbeeh_tap_zone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="30dp"
        android:gravity="center"
        android:orientation="vertical">

        <!-- Dhikr name in Arabic (gold) -->
        <TextView
            android:id="@+id/tasbeeh_dhikr_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:text="سُبْحَانَ اللَّه"
            android:textColor="#FFE8B0"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!-- Big count number -->
        <TextView
            android:id="@+id/tasbeeh_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="center"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="46sp"
            android:textStyle="bold" />

        <!-- Progress "X / Y" -->
        <TextView
            android:id="@+id/tasbeeh_progress_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="0 / 33"
            android:textColor="#9BB89D"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- Bottom action row: Reset (left) | Next (right) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:layout_gravity="bottom"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tasbeeh_btn_reset"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="@drawable/widget_btn_ghost"
            android:gravity="center"
            android:paddingHorizontal="10dp"
            android:text="إعادة"
            android:textColor="#8FB89A"
            android:textSize="10sp" />

        <ImageView
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tasbeeh_btn_next"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="@drawable/noor_widget_pill"
            android:gravity="center"
            android:paddingHorizontal="10dp"
            android:text="التالي ›"
            android:textColor="#1E3822"
            android:textSize="10sp"
            android:textStyle="bold" />

    </LinearLayout>

</FrameLayout>
