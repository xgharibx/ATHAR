<?xml version="1.0" encoding="utf-8"?>
<!--
  Interactive Tasbeeh Widget (2×2) — Athar premium design
  A glowing gold gradient ring (Canvas bitmap) wraps the live count.
  Tap anywhere in the ring to count; ghost reset + gold next below.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/tasbeeh_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/noor_widget_background">

    <!-- Living sky (WidgetCanvas.clockPhase/sky) — approximate time-of-day
         mood background, this widget has no prayer-schedule data of its own. -->
    <ImageView
        android:id="@+id/tasbeeh_sky"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:importantForAccessibility="no" />

    <ImageView
        android:id="@+id/tasbeeh_stars"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:importantForAccessibility="no" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="10dp">

        <!-- Tap zone with the ring + count stack -->
        <FrameLayout
            android:id="@+id/tasbeeh_tap_zone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="50dp">

            <ImageView
                android:id="@+id/tasbeeh_ring"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:layout_margin="2dp"
                android:scaleType="fitCenter"
                android:importantForAccessibility="no" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tasbeeh_dhikr_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="1"
                    android:paddingHorizontal="26dp"
                    android:text="سُبْحَانَ اللَّه"
                    android:textColor="@color/widget_text_accent"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tasbeeh_count"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="0"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="44sp"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tasbeeh_progress_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="0 / 33"
                    android:textColor="@color/widget_text_secondary"
                    android:textSize="10sp" />
            </LinearLayout>
        </FrameLayout>

        <!-- Bottom actions — each pill sits in its own 48dp tap zone (WL-4.2
             touch-target minimum) while staying visually compact; reset and
             next are distinct actions from the root's "open app" tap, so
             unlike the pill buttons on other widgets (which share their
             root's action and don't need a separate hit-target fix), a
             near-miss here would otherwise trigger the wrong thing. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_gravity="bottom"
            android:orientation="horizontal">

            <FrameLayout
                android:id="@+id/tasbeeh_reset_zone"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center">
                <!-- widget_btn_ghost is a fixed dark-green brand button with
                     no night variant — text must stay a fixed light color,
                     not a @color/widget_text_* token (see
                     widget_dashboard.xml's ghost button for what goes wrong
                     otherwise). -->
                <TextView
                    android:id="@+id/tasbeeh_btn_reset"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:background="@drawable/widget_btn_ghost"
                    android:gravity="center"
                    android:paddingHorizontal="10dp"
                    android:text="إعادة"
                    android:textColor="#A9CBB0"
                    android:textSize="10sp" />
            </FrameLayout>

            <ImageView
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:importantForAccessibility="no" />

            <FrameLayout
                android:id="@+id/tasbeeh_next_zone"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center">
                <!-- noor_widget_pill is a fixed gold-gradient brand button
                     with no night variant — text must stay a fixed dark
                     color. -->
                <TextView
                    android:id="@+id/tasbeeh_btn_next"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:background="@drawable/noor_widget_pill"
                    android:gravity="center"
                    android:paddingHorizontal="10dp"
                    android:text="التالي ›"
                    android:textColor="#26301B"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold" />
            </FrameLayout>
        </LinearLayout>

    </FrameLayout>

</FrameLayout>
