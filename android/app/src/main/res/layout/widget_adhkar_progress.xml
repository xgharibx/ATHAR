<?xml version="1.0" encoding="utf-8"?>
<!--
  Daily Adhkar Progress Widget (4×2) — Athar premium design
  Canvas-rendered gradient bars (sunrise gold / dusk indigo) with glow,
  Hijri date header, gold action pill. Bars bound via setImageViewBitmap.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/adhkar_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_adhkar"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/adhkar_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="start"
            android:textColor="#8FBCC8"
            android:textSize="10sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="أذكاري اليوم"
            android:textColor="#EAF6FA"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:text="أذكار الصباح ☀️"
                android:textColor="#FFE8B0"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/adhkar_morning_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:gravity="start"
                android:text="--/--"
                android:textColor="#F6DFA4"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold" />
        </LinearLayout>

        <ImageView
            android:id="@+id/adhkar_morning_bar"
            android:layout_width="match_parent"
            android:layout_height="9dp"
            android:layout_marginTop="5dp"
            android:scaleType="fitXY"
            android:importantForAccessibility="no" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:text="أذكار المساء 🌙"
                android:textColor="#C8CCFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/adhkar_evening_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:gravity="start"
                android:text="--/--"
                android:textColor="#B8BEFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold" />
        </LinearLayout>

        <ImageView
            android:id="@+id/adhkar_evening_bar"
            android:layout_width="match_parent"
            android:layout_height="9dp"
            android:layout_marginTop="5dp"
            android:scaleType="fitXY"
            android:importantForAccessibility="no" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="start"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/adhkar_open_btn"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:background="@drawable/noor_widget_pill"
            android:gravity="center"
            android:paddingHorizontal="14dp"
            android:text="افتح الأذكار"
            android:textColor="#26301B"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
