<?xml version="1.0" encoding="utf-8"?>
<!--
  Prayer Countdown Widget (4×2) — Athar premium design
  Sky-phase gradient background (set from Java by next prayer), interval
  progress ring (Canvas bitmap), hero countdown, prayer name + time.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/noor_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/noor_widget_background">

    <!-- Continuous sky (WidgetCanvas.sky) — LERPs between phase colors by
         interval progress instead of jumping between 5 static drawables. -->
    <ImageView
        android:id="@+id/prayer_sky"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:importantForAccessibility="no" />

    <ImageView
        android:id="@+id/prayer_stars"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:importantForAccessibility="no" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="10dp">

    <!-- Interval ring with mini time centered -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.42">

        <ImageView
            android:id="@+id/prayer_ring"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:scaleType="fitCenter"
            android:importantForAccessibility="no" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/prayer_ring_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="--:--"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/prayer_ring_ampm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#C9DCC9"
                android:textSize="10sp" />
        </LinearLayout>
    </FrameLayout>

    <!-- Texts -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.58"
        android:layout_marginStart="10dp"
        android:gravity="end"
        android:orientation="vertical">

        <TextView
            android:id="@+id/noor_widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="الصلاة القادمة"
            android:textColor="#C9DCC9"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/noor_widget_phrase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:ellipsize="end"
            android:gravity="end"
            android:maxLines="1"
            android:includeFontPadding="false"
            android:text="العشاء"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold" />

        <!-- A real Chronometer, not a TextView: the OS ticks this live,
             second by second, with zero app-process/broadcast involvement —
             genuinely live, not "updates whenever the widget happens to
             refresh." Falls back to a static TextView pre-Android 7.0
             (isCountDown needs API 24); see NoorPrayerWidgetProvider. -->
        <Chronometer
            android:id="@+id/prayer_countdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:gravity="end"
            android:text=""
            android:textColor="#FFE8B0"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/prayer_countdown_static"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:gravity="end"
            android:text=""
            android:textColor="#FFE8B0"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/noor_widget_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:gravity="end"
            android:textColor="#A9C4A9"
            android:textSize="9sp" />
    </LinearLayout>

    </LinearLayout>

</FrameLayout>
