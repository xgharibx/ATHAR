<?xml version="1.0" encoding="utf-8"?>
<!--
  Daily Hadith Widget (4×2) — Athar premium design.
  Shows the SAME real hadeethenc.com daily hadith as the home-page card
  (text + attribution + grade — no AI, nothing invented), synced from the
  web app via syncSunnahWidget(). Falls back to a rotating real "forgotten
  sunnah" phrase (AtharWidgetSpec) before the app has run once. Living
  sky background, same treatment as Adhkar/Wird/Tasbeeh/Asma.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/noor_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/noor_widget_background">

    <ImageView
        android:id="@+id/sunnah_sky"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:importantForAccessibility="no" />

    <ImageView
        android:id="@+id/sunnah_stars"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:importantForAccessibility="no" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/noor_widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textColor="@color/widget_text_accent"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/noor_widget_phrase"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="6dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center_vertical|end"
            android:maxLines="3"
            android:textColor="@color/widget_text_primary"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/sunnah_attribution"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="end"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/widget_text_secondary"
            android:textSize="10sp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- noor_widget_pill is a fixed gold-gradient brand button with no
                 night variant — text must stay a fixed dark color. -->
            <TextView
                android:id="@+id/noor_widget_action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/noor_widget_pill"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:textColor="#2F4F37"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/noor_widget_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:textColor="@color/widget_text_secondary"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
