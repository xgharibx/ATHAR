<?xml version="1.0" encoding="utf-8"?>
<!--
  Daily Quran Wird Widget (4×2) — Athar premium design
  Hero ayah count, emerald Canvas progress bar with glow, gold pill.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/wird_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/noor_widget_background">

    <!-- Living sky (WidgetCanvas.clockPhase/sky) — approximate time-of-day
         mood background, this widget has no prayer-schedule data of its own. -->
    <ImageView
        android:id="@+id/wird_sky"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:importantForAccessibility="no" />

    <ImageView
        android:id="@+id/wird_stars"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:importantForAccessibility="no" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/wird_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="start"
            android:textColor="@color/widget_text_secondary"
            android:textSize="10sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="ورد القرآن"
            android:textColor="@color/widget_text_accent"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="start"
            android:orientation="vertical">

            <TextView
                android:id="@+id/wird_ayahs_read"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 آية"
                android:textColor="@color/widget_text_primary"
                android:textSize="26sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/wird_goal_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="اليوم"
                android:textColor="@color/widget_text_secondary"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:orientation="vertical">

            <TextView
                android:id="@+id/wird_surah_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="سورة الفاتحة"
                android:textColor="@color/widget_text_accent"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/wird_ayah_ref"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="الآية ١"
                android:textColor="@color/widget_text_secondary"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

    <ImageView
        android:id="@+id/wird_bar"
        android:layout_width="match_parent"
        android:layout_height="10dp"
        android:layout_marginTop="6dp"
        android:scaleType="fitXY"
        android:importantForAccessibility="no" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="7dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/wird_progress_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="start"
            android:text="0% من الهدف"
            android:textColor="@color/widget_text_secondary"
            android:textSize="10sp" />

        <!-- noor_widget_pill is a fixed gold-gradient brand button with no
             night variant — text must stay a fixed dark color, not a
             @color/widget_text_* token (see widget_dashboard.xml's ghost
             button for what goes wrong otherwise). -->
        <TextView
            android:id="@+id/wird_open_btn"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:background="@drawable/noor_widget_pill"
            android:gravity="center"
            android:paddingHorizontal="14dp"
            android:text="متابعة القراءة"
            android:textColor="#26301B"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold" />
    </LinearLayout>

    </LinearLayout>

</FrameLayout>
