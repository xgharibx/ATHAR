# ATHAR environment template
# انسخ هذا الملف إلى .env.local ثم عدّل القيم حسب بيئتك.

# Leaderboard API endpoint (Supabase Edge Function)
# مثال:
# VITE_LEADERBOARD_ENDPOINT=https://<project-ref>.functions.supabase.co/leaderboard
VITE_LEADERBOARD_ENDPOINT=

# Optional: required if your endpoint gateway enforces apikey/jwt for Edge Functions
VITE_LEADERBOARD_ANON_KEY=

# IMPORTANT:
# Do NOT put LEADERBOARD_ADMIN_TOKEN here.
# Keep the admin token only in Supabase Edge Function secrets,
# then paste it manually inside the in-app admin panel when needed.

# Optional: bump this value on release to force icon refresh for installed PWA clients
# Example: VITE_ICON_REV=2026-02-14-r2
VITE_ICON_REV=

# Optional: runtime stamp used to force a soft reload once per release (set automatically in CI)
# Example: VITE_RUNTIME_VERSION=git-sha-or-release-tag
VITE_RUNTIME_VERSION=
